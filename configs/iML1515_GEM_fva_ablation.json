{
  "model_name": "iML1515_GEM",
  "organism": "E coli",
  "biomass_reaction": null,
  "enzyme_upper_bound": 0.25,
  "solver": "glpk",
  "enable_fva": true,
  "enable_biolog_validation": false,

  "fva": {
    "parallel": true,
    "workers": 8,
    "chunk_size": 50,
    "method": "dask",
    "_comment_method": "Use dask for better task scheduling and monitoring - verified working in SLURM",
    "_comment_workers": "Set to match SLURM_CPUS_PER_TASK for optimal performance",
    "_comment_chunk_size": "Number of reactions per task. Smaller chunks = better memory efficiency"
  },

  "simulated_annealing": {
    "temperature": 100,
    "cooling_rate": 0.95,
    "min_temperature": 0.001,
    "max_iterations": 1000,
    "max_unchanged_iterations": 50,
    "change_threshold": 0.001,
    "biomass_goal": 0.2,
    "n_top_enzymes": 20,
    "verbose": false,
    "adaptive_strategies": {
      "enable_restart": true,
      "restart_threshold": 0.001,
      "restart_frequency": 100,
      "enable_dynamic_step_size": false,
      "step_size_reduction": 0.8,
      "enable_multi_objective": false
    }
}
}

